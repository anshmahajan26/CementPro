# ─── FRONTEND ENVIRONMENT VARIABLES EXAMPLE ───────────────────────────────────
# Copy this file to .env for local development.
# For production (Render), set these in the Render Dashboard → Environment.

# LOCAL:      VITE_API_URL=http://localhost:5000
# PRODUCTION: VITE_API_URL=https://cementpro-backend.onrender.com
VITE_API_URL=http://localhost:5000

VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
